{
  "name": "friendcircle",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "start:tunnel": "node ./node_modules/expo/bin/cli start --clear --tunnel --port 8083",
    "dev": "node ./node_modules/expo/bin/cli start --tunnel --port 8083",
    "dev:android": "node ./node_modules/expo/bin/cli start --tunnel --port 8083",
    "dev:emulator": "node ./node_modules/expo/bin/cli start --tunnel --port 8083 --android",
    "android": "expo start --android",
    "build:apk": "eas build -p android --profile preview",
    "build:aab": "eas build -p android --profile production",
    "build:apk:novcs": "set EAS_NO_VCS=1&& set EAS_PROJECT_ROOT=D:\\VSCode\\FriendCircle&& eas build -p android --profile preview",
    "build:aab:novcs": "set EAS_NO_VCS=1&& set EAS_PROJECT_ROOT=D:\\VSCode\\FriendCircle&& eas build -p android --profile production",
    "build:apk:local": "set EAS_NO_VCS=1&& set EAS_PROJECT_ROOT=D:\\VSCode\\FriendCircle&& eas build -p android --profile preview --local",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@react-navigation/stack": "^7.8.4",
    "@supabase/supabase-js": "^2.98.0",
    "babel-preset-expo": "~55.0.8",
    "base64-arraybuffer": "^1.0.2",
    "dayjs": "^1.11.19",
    "expo": "~55.0.5",
    "expo-av": "~16.0.7",
    "expo-checkbox": "~55.0.3",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.13",
    "expo-media-library": "~55.0.10",
    "expo-notifications": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-video": "~55.0.11",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "0.7.2",
    "uuid": "^13.0.0"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "eas-cli": "^18.1.0"
  }
}
